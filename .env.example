# -------------------------------------------------------
# BilimAI – Environment Variables
# Copy this file to .env and fill in the values.
# -------------------------------------------------------

# Django core
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DEBUG=false
# Your PythonAnywhere domain, e.g.: yourusername.pythonanywhere.com
ALLOWED_HOSTS=yourusername.pythonanywhere.com

# CORS – comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://yourusername.pythonanywhere.com

# -------------------------------------------------------
# Database
# Leave USE_POSTGRES=false to use SQLite (simplest option).
# Set USE_POSTGRES=true and fill in the fields below to
# use PostgreSQL (requires a paid PythonAnywhere plan or
# an external DB such as Neon/Supabase).
# -------------------------------------------------------
USE_POSTGRES=false
# POSTGRES_DB=bilimai
# POSTGRES_USER=bilimai
# POSTGRES_PASSWORD=your-db-password
# POSTGRES_HOST=your-db-host
# POSTGRES_PORT=5432

# -------------------------------------------------------
# Redis / Celery  (optional – leave blank to disable)
# PythonAnywhere free tier does NOT support Redis.
# On paid plans you can use Redis To Go or a remote Redis.
# -------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# -------------------------------------------------------
# AI providers
# -------------------------------------------------------
OPENAI_API_KEY=
OPENROUTER_API_KEY=
HF_API_TOKEN=
OPENAI_API_URL=https://router.huggingface.co/v1/chat/completions
OPENAI_MODEL=openai/gpt-oss-120b

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
